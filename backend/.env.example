# PostgreSQL connection used by Prisma. Matches docker-compose.yml.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/invoiceflow?schema=public"

# API server port.
PORT=8080

# Comma-separated frontend origins allowed to call the API with credentials.
CORS_ORIGIN="http://localhost:5173,https://your-vercel-app.vercel.app"

# Minimum 24 characters. Use a long random value in production.
JWT_SECRET="replace-with-at-least-24-random-characters"
JWT_EXPIRES_IN="30m"

# Local HTTP defaults. For cross-site Vercel -> API over HTTPS, use:
# COOKIE_SECURE=true
# COOKIE_SAME_SITE=none
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
