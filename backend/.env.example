# Database Configuration
DATABASE_URL="postgresql://user:password@localhost:5432/invoiceflow"

# JWT Secrets (must be at least 32 characters, unique, and kept secret)
JWT_SECRET="your-access-token-secret-32-chars-or-more-change-in-prod-12345"
REFRESH_TOKEN_SECRET="your-refresh-token-secret-32-chars-or-more-change-prod-12345"

# CORS Configuration (comma-separated origins)
CORS_ORIGIN="http://localhost:5173,http://localhost:3000,https://yourdomain.com"

# Security
COOKIE_SECURE="false"
NODE_ENV="development"

# Server
PORT="8080"
